<?xml version="1.0"?>
<robot name="first_robot">
    <!-- 机器人身体部分 -->
    <link name="base_link">
        <!--部件外观描述-->
        <visual>
            <!--沿着机器人几何中心的偏移和旋转描述-->
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <!--几何形状   -->
            <geometry>
            <!-- 这里可以选择不同的几何形状，如圆柱体、立方体等 ,现在是圆柱体--> 
                <cylinder radius="0.1" length="0.12"/>
                
            </geometry>
            <!--材质颜色描述-->
            <material name="white">
                <color rgba="1.0 1.0 1.0 0.5"/>
            </material>
        </visual>
    </link>

    <!-- 机器人IMU部分,惯性测量传感器 -->
    <link name="imu_link">
        <!--部件外观描述-->
        <visual>
            <!--沿着机器人几何中心的偏移和旋转描述-->
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <!--几何形状   -->
            <geometry>
            <!-- 这里可以选择不同的几何形状，如圆柱体、立方体等 ,现在是圆柱体--> 
                <box size="0.02 0.02 0.02"/>
                
            </geometry>
            <!--材质颜色描述-->
            <material name="black">
                <color rgba="0.0 0.0 0.0 0.5"/>
            </material>
        </visual>
    </link>

    <!-- 机器人的关节,IMU与身体的连接 -->
    <joint name="imu_joint" type="fixed">
        <!--连接的父链接和子链接-->
        <parent link="base_link"/>
        <child link="imu_link"/>
        <!--关节位置描述-->
        <origin xyz="0.0 0.0 0.03" rpy="0.0 0.0 0.0"/>
    </joint>
</robot>