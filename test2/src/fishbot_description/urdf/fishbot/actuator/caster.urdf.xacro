<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    
    <xacro:include filename="$(find fishbot_description)/urdf/fishbot/common_inertia.xacro"/>
    <!-- 机器人wheel部分,惯性测量传感器 -->
    <xacro:macro name="caster_xacro" params="caster_name xyz">
         <link name="${caster_name}_caster_link">
            <!--部件外观描述-->
            <visual>
                <!--沿着机器人几何中心的偏移和旋转描述-->
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <!--几何形状   -->
                <geometry>
                <!-- 这里可以选择不同的几何形状，如圆柱体、立方体等 ,现在是圆柱体--> 
                    <sphere radius="0.016"/>
                    
                </geometry>
                <!--材质颜色描述-->
                <material name="yellow">
                    <color rgba="1.0 1.0 0.0 0.8"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0.0 0.0 0.0" />
                <geometry>
                    <sphere radius="0.016"/>
                </geometry>
                <material name="yellow">
                    <color rgba="1.0 1.0 0.0 0.8"/>
                </material>
            </collision>
            <xacro:sphere_inertia m="0.01" r="0.016" />
        </link>
        <gazebo reference="${caster_name}_caster_link">
            <mu1 value="0.0"/>
            <mu2 value="0.0"/>
            <kp value="1000000000.0"/>
            <kd value="1.0"/>
        </gazebo>
        <!-- 机器人的关节,wheel与身体的连接 -->
        <joint name="${caster_name}_caster_joint" type="fixed">
            <!--连接的父链接和子链接-->
            <parent link="base_link"/>
            <child link="${caster_name}_caster_link"/>
            <!--关节位置描述-->
            <origin xyz="${xyz}" />
            <axis xyz="0 0 0"/>
        </joint>
        
        
    </xacro:macro>
        
  
    
</robot>